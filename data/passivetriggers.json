    "heal_self":           { "label": "Heal Self (% maxHp)",
                             "params": { "percent": { "type": "percent",  "default": 0.1,  "label": "% of max HP" } } },
    "heal_self_pct_dmg":   { "label": "Heal Self (% of damage)",
                             "params": { "percent": { "type": "percent",  "default": 0.25, "label": "% of damage" } } },
    "damage_target":       { "label": "Damage Target (% target maxHp)",
                             "params": { "percent": { "type": "percent",  "default": 0.15, "label": "% of target max HP" } } },
    "reflect_damage":      { "label": "Reflect Damage (% taken)",
